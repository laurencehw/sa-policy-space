# SA Policy Space — Environment Variables
# Copy to .env.local and fill in values

# ── Supabase (production) ────────────────────────────────────────────────────
# When set, the app fetches from Supabase. When absent, falls back to SQLite.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic (brief generator) ──────────────────────────────────────────────
# Required for /api/generate-brief. Without this, brief generation returns 500.
ANTHROPIC_API_KEY=

# ── Local development (SQLite) ───────────────────────────────────────────────
# Absolute path to the SQLite database file. Only used when Supabase vars are unset.
# SQLITE_DB_PATH=G:/My Drive/book drafts/the south african economy/policy_space/data/dev.sqlite3
